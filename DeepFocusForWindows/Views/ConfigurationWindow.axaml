<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DeepFocusForWindows.ViewModels"
        x:Class="DeepFocusForWindows.Views.ConfigurationWindow"
        x:DataType="vm:ConfigurationViewModel"
        Title="DeepFocus – Configuration"
        Width="620" Height="580"
        MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/avalonia-logo.ico">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="14">

            <!-- ─── Focus Applications ─────────────────────────────────── -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Focus Applications"
                           FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Content="↺  Refresh"
                            Command="{Binding RefreshWindowsCommand}"
                            IsVisible="{Binding IsEditingFocusApps}"/>
                    <Button Content="{Binding EditButtonText}"
                            Command="{Binding ToggleFocusAppsEditCommand}"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="These windows will remain fully visible while dimming is active."
                       TextWrapping="Wrap" Opacity="0.7"/>

            <!-- Search box — only visible while editing -->
            <TextBox Watermark="Search by title or process name…"
                     Text="{Binding SearchText}"
                     IsVisible="{Binding IsSearchVisible}"/>

            <!-- Hint shown when no apps selected and not editing -->
            <TextBlock Text="No focus apps selected. Click Edit to add some."
                       IsVisible="{Binding NoSelectionHintVisible}"
                       Opacity="0.55" FontStyle="Italic"/>

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4" Height="180"
                    IsVisible="{Binding !NoSelectionHintVisible}">
                <ListBox ItemsSource="{Binding FilteredWindows}"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerTheme>
                        <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </ControlTheme>
                    </ListBox.ItemContainerTheme>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:WindowInfoViewModel">
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Padding="8 4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ProcessNameLabel}"
                                               Opacity="0.6" FontSize="11"
                                               Margin="10 0 0 0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- ─── Dimming Settings ──────────────────────────────────── -->
            <Separator Margin="0 6"/>
            <TextBlock Text="Dimming Settings"
                       FontSize="16" FontWeight="SemiBold"/>

            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="Level:" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Margin="10 0"
                        Minimum="0" Maximum="100"
                        Value="{Binding DimmingLevel}"
                        TickFrequency="10" IsSnapToTickEnabled="False"/>
                <TextBlock Grid.Column="2" Text="{Binding DimmingLevelText}"
                           VerticalAlignment="Center" Width="40"/>
            </Grid>

            <CheckBox IsChecked="{Binding IsDimmingEnabled}"
                      Content="Enable dimming"/>

            <TextBlock Text="💡 Press ESC twice quickly to temporarily disable dimming."
                       Opacity="0.6" FontSize="11" TextWrapping="Wrap"/>

            <!-- ─── Focus Session ─────────────────────────────────────── -->
            <Separator Margin="0 6"/>
            <CheckBox IsChecked="{Binding AutoDimOnFocusSession}"
                      IsEnabled="{Binding IsFocusSessionSupported}"
                      Content="Automatically dim only while a Windows Focus Session is active"/>
            <TextBlock IsVisible="{Binding !IsFocusSessionSupported}"
                       Text="(Windows Focus Sessions not available on this device)"
                       Opacity="0.5" FontSize="11"/>

            <!-- ─── Startup ───────────────────────────────────────────── -->
            <Separator Margin="0 6"/>
            <CheckBox IsChecked="{Binding StartOnBoot}"
                      Content="Start DeepFocus when Windows starts"/>

            <!-- ─── Actions ───────────────────────────────────────────── -->
            <Separator Margin="0 6"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close"
                        Command="{Binding CloseCommand}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
